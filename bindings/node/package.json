{
  "name": "@axiom-rules/core",
  "version": "0.1.0",
  "description": "Axiom rules engine — Node.js / TypeScript native binding",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/axiom-rules/axiom"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "axiom.*.node"
  ],
  "scripts": {
    "build":       "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test":        "node --test tests/",
    "prepublishOnly": "napi build --platform --release"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "typescript":   "^5.0.0"
  },
  "napi": {
    "name":    "axiom",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  }
}
